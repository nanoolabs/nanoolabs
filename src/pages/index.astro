---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import { SITE, SOCIALS } from "@consts";
import { ICONS } from "@lib/icons";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);
---

<Layout title="Home" description={SITE.DESCRIPTION}>
  <Container>
    <div class="space-y-16 sm:space-y-24">
      <section class="animate py-8">
        <div class="mb-8">
          <div
            class="flex size-24 items-center justify-center overflow-hidden rounded-xl border border-zinc-200 dark:border-zinc-800"
          >
            <div class="size-20 text-black dark:text-white">
              <Fragment set:html={ICONS.LOGO} />
            </div>
          </div>
        </div>
        <article class="space-y-4">
          <h1 class="text-2xl font-semibold text-black dark:text-white">
            A Lab for Experiments.
          </h1>
          <blockquote
            class="mt-4 border-l-2 border-zinc-300 pl-4 text-zinc-600 italic dark:border-zinc-700 dark:text-white/70"
          >
            "Built fast, simple, and scalable"
          </blockquote>
          <div class="mt-4 text-zinc-600 dark:text-white/70">
            Nanoolabs is a development lab for <strong>nanoo.biz.id</strong>. I
            experiment with Cloud, Edge, and Business logic to create simple and
            effective solutions.
          </div>
        </article>
        <nav class="flex flex-wrap gap-2 pt-6">
          <a
            href="https://docs.nanoolabs.dev"
            class="rounded-sm border border-black/15 bg-zinc-100 px-3 py-1.5 text-sm transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black dark:border-white/25 dark:bg-[#0a0a0a] dark:hover:bg-white/5 dark:hover:text-white"
          >
            Read the docs
          </a>
          <a
            href="/projects"
            class="rounded-sm border border-black/15 bg-zinc-100 px-3 py-1.5 text-sm transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black dark:border-white/25 dark:bg-[#0a0a0a] dark:hover:bg-white/5 dark:hover:text-white"
          >
            View projects
          </a>
        </nav>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap items-center justify-between gap-y-2">
          <h2 class="font-semibold text-black dark:text-white">Latest posts</h2>
          <a
            href="/blog"
            class="text-sm text-zinc-500 underline decoration-zinc-300 transition-colors hover:text-black hover:decoration-black dark:text-white/50 dark:decoration-white/30 dark:hover:text-white dark:hover:decoration-white"
          >
            See all posts
          </a>
        </div>
        <ul class="not-prose flex flex-col gap-4">
          {
            blog.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))
          }
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap items-center justify-between gap-y-2">
          <h2 class="font-semibold text-black dark:text-white">
            Recent projects
          </h2>
          <a
            href="/projects"
            class="text-sm text-zinc-500 underline decoration-zinc-300 transition-colors hover:text-black hover:decoration-black dark:text-white/50 dark:decoration-white/30 dark:hover:text-white dark:hover:decoration-white"
          >
            See all projects
          </a>
        </div>
        <ul class="not-prose flex flex-col gap-4">
          {
            projects.map((project) => (
              <li>
                <ArrowCard entry={project} />
              </li>
            ))
          }
        </ul>
      </section>

      <section class="animate space-y-4">
        <h2 class="font-semibold text-black dark:text-white">Contact</h2>
        <article>
          <p>Feel free to contact me for collaboration or any questions.</p>
        </article>
        <ul class="not-prose flex flex-wrap gap-2">
          {
            SOCIALS.filter((s) => s.NAME.toLowerCase() !== "github").map(
              (SOCIAL) => (
                <li class="flex gap-x-2 text-nowrap">
                  <a
                    href={SOCIAL.HREF}
                    target="_blank"
                    class="rounded-sm border border-black/15 bg-zinc-100 px-3 py-1.5 text-sm transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black dark:border-white/25 dark:bg-[#0a0a0a] dark:hover:bg-white/5 dark:hover:text-white"
                    aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`}
                  >
                    {SOCIAL.NAME}
                  </a>
                </li>
              ),
            )
          }
        </ul>
      </section>
    </div>
  </Container>
</Layout>
