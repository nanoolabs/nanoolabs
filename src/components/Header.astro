---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE, SOCIALS } from "@consts";
import { ICONS } from "@lib/icons";
---

<header transition:persist>
  <div class="nav-container">
    <Link href="/" underline={false}>
      <div class="flex items-center gap-2">
        <div class="size-8 text-black dark:text-white">
          <Fragment set:html={ICONS.LOGO} />
        </div>
        <div class="font-semibold text-black dark:text-white">
          {SITE.TITLE}
        </div>
      </div>
    </Link>

    <nav class="hidden items-center gap-1 text-sm sm:flex">
      <Link
        href="/blog"
        class="px-2 py-1 text-black/50 transition-colors duration-300 hover:text-black dark:text-white/50 dark:hover:text-white"
        underline={false}
      >
        blog
      </Link>
      <span class="text-black/15 dark:text-white/15">
        {`/`}
      </span>
      <Link
        href="/projects"
        class="px-2 py-1 text-black/50 transition-colors duration-300 hover:text-black dark:text-white/50 dark:hover:text-white"
        underline={false}
      >
        projects
      </Link>
      <span class="text-black/15 dark:text-white/15">
        {`/`}
      </span>
      <button
        id="magnifying-glass"
        aria-label="Search"
        class="ml-1 flex items-center rounded-sm border border-black/15 bg-zinc-100 px-3 py-1.5 text-xs transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black focus-visible:bg-black/5 focus-visible:text-black dark:border-white/25 dark:bg-[#0a0a0a] dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white"
      >
        <Fragment set:html={ICONS.SEARCH} />
        &nbsp;Search
      </button>
    </nav>

    <div class="flex items-center gap-0.5 sm:hidden">
      <button
        id="hamburger-button"
        aria-label="Open mobile menu"
        class="flex items-center px-1.5 py-1.5 text-black/50 transition-colors duration-300 ease-in-out hover:text-black dark:text-white/50 dark:hover:text-white"
      >
        <div class="size-7">
          <Fragment set:html={ICONS.HAMBURGER} />
        </div>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 -translate-x-full transform bg-black/50 backdrop-blur-xs transition-transform duration-300 sm:hidden"
  >
    <div class="flex h-full w-64 flex-col bg-white p-6 dark:bg-[#050505]">
      <button
        id="close-mobile-menu"
        aria-label="Close mobile menu"
        class="self-end p-2.5 text-black/50 transition-colors duration-300 ease-in-out hover:text-black dark:text-white/50 dark:hover:text-white"
      >
        <div class="size-7">
          <Fragment set:html={ICONS.CLOSE} />
        </div>
      </button>

      <nav class="mt-4 flex flex-col gap-2">
        <Link
          href="/blog"
          underline={false}
          class="rounded-sm px-3 py-2 text-lg text-black/60 transition-colors duration-300 hover:bg-black/5 hover:text-black dark:text-white/60 dark:hover:bg-white/5 dark:hover:text-white"
        >
          blog
        </Link>
        <Link
          href="/projects"
          underline={false}
          class="rounded-sm px-3 py-2 text-lg text-black/60 transition-colors duration-300 hover:bg-black/5 hover:text-black dark:text-white/60 dark:hover:bg-white/5 dark:hover:text-white"
        >
          projects
        </Link>
        <button
          id="magnifying-glass-mobile"
          aria-label="Search"
          class="mt-2 flex items-center rounded-sm border border-black/15 bg-zinc-100 px-3 py-2.5 text-base transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black dark:border-white/25 dark:bg-[#0a0a0a] dark:hover:bg-white/5 dark:hover:text-white"
        >
          <div class="size-5">
            <Fragment set:html={ICONS.SEARCH} />
          </div>
          &nbsp;Search
        </button>
      </nav>

      <div class="mt-auto border-t border-black/10 pt-6 dark:border-white/10">
        <div class="flex flex-wrap gap-2">
          {
            SOCIALS.map((social) => (
              <a
                href={social.HREF}
                target="_blank"
                aria-label={social.NAME}
                class="flex size-10 items-center justify-center rounded-sm text-black/50 transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black dark:text-white/50 dark:hover:bg-white/5 dark:hover:text-white"
              >
                <div class="size-6">
                  {social.NAME === "X" && <Fragment set:html={ICONS.X} />}
                  {social.NAME === "GitHub" && (
                    <Fragment set:html={ICONS.GITHUB} />
                  )}
                  {social.NAME === "Instagram" && (
                    <Fragment set:html={ICONS.INSTAGRAM} />
                  )}
                  {social.NAME === "Email" && (
                    <Fragment set:html={ICONS.EMAIL} />
                  )}
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const hamburgerButton = document.getElementById("hamburger-button");
  const closeMobileMenuButton = document.getElementById("close-mobile-menu");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileSearchButton = document.getElementById("magnifying-glass-mobile");
  const desktopSearchButton = document.getElementById("magnifying-glass");

  hamburgerButton?.addEventListener("click", () => {
    mobileMenu?.classList.remove("-translate-x-full");
    document.body.classList.add("no-scroll");
  });

  closeMobileMenuButton?.addEventListener("click", () => {
    mobileMenu?.classList.add("-translate-x-full");
    document.body.classList.remove("no-scroll");
  });

  mobileMenu?.addEventListener("click", (event) => {
    if (event.target === mobileMenu) {
      mobileMenu?.classList.add("-translate-x-full");
      document.body.classList.remove("no-scroll");
    }
  });

  const mobileNavLinks = mobileMenu?.querySelectorAll("nav a");
  mobileNavLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("-translate-x-full");
      document.body.classList.remove("no-scroll");
    });
  });

  mobileSearchButton?.addEventListener("click", () => {
    mobileMenu?.classList.add("-translate-x-full");
    document.body.classList.remove("no-scroll");
    desktopSearchButton?.click();
  });
</script>
